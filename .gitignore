# ─────────────────────────────────────────────────────────────
# pump.detect / predictive_maintenance_anomaly_detection
# Combined .gitignore for monorepo (training pipeline + web app)
# ─────────────────────────────────────────────────────────────

# ── Python ──
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
.eggs/
build/
dist/
sdist/
wheels/
*.manifest
*.spec
.installed.cfg
MANIFEST

# Virtual environments
.venv/
venv/
env/
ENV/
.python-version

# Environment variables
.env
.env.local
.envrc

# Tests / coverage
.pytest_cache/
.tox/
.nox/
.coverage
.coverage.*
htmlcov/
coverage.xml
nosetests.xml
*.cover
.hypothesis/
.cache/

# Type checkers / linters
.mypy_cache/
.dmypy.json
.pyre/
.pytype/
.ruff_cache/

# Jupyter
.ipynb_checkpoints/
profile_default/
ipython_config.py

# ── Node / Frontend ──
node_modules/
.vite/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# Frontend build output (Vite emits to dist/, already covered above by `dist/`)
# app/frontend/dist/  ← redundant, kept here for clarity

# ── Model artifacts (too large for git, distribute separately) ──
*.pkl
*.joblib
*.pt
*.pth
*.onnx
*.h5
*.ckpt
*.safetensors

# Generated dataset / array files
*.npy
*.npz

# ── Raw / processed datasets (not redistributable) ──
# Keep .gitkeep placeholders so the empty dirs are tracked.
/data/raw/*
!/data/raw/.gitkeep
/data/processed/*
!/data/processed/.gitkeep
!/data/processed/dataset1/.gitkeep
!/data/processed/dataset2/.gitkeep
processed_data/

# CSV data lives only under /data/ and SKAB/ — do NOT blanket-ignore *.csv,
# because the web app may ship a sample CSV under app/backend/.
/data/**/*.csv
/SKAB/valve1/*.csv
/SKAB/valve2/*.csv
/SKAB/other/*.csv
/SKAB/anomaly-free/*.csv
/SKAB/eda_output/

# ── Web app: backend trained-model directory ──
# Models are mounted at runtime, never committed.
app/backend/artifacts/*
!app/backend/artifacts/.gitkeep

# ── Reports / local exports ──
*.pdf
!docs/**/*.pdf
*.report.pdf

# ── OS / IDE ──
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~

# ── Misc ──
.cursorignore
.cursorindexingignore
.abstra/
celerybeat-schedule
celerybeat.pid
