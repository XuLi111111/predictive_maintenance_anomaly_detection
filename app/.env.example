# pump.detect — runtime configuration template.
# Copy to `.env` (already gitignored) and override per-environment values.

# ── Backend ──────────────────────────────────────────────────────
# Where the .pkl / scaler.pkl / model_transformer.pt artifacts live.
ARTIFACT_DIR=./backend/artifacts

# Where uploaded CSVs are temporarily staged. Defaults to the OS temp dir.
# UPLOAD_TMP_DIR=/tmp/pump_detect_uploads

# Maximum upload size in megabytes (T1 enforces this).
MAX_UPLOAD_MB=50

# Default alert threshold for /api/predict and /api/stream (FR-16).
ALERT_THRESHOLD=0.5

# Sliding window parameters — must match training (NFR-05).
WINDOW_SIZE=20
HORIZON=10

# CORS origins for `vite dev` mode and any standalone front-end deploys.
CORS_ORIGINS=http://localhost:5173,http://localhost,http://localhost:8080
